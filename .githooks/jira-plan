#!/usr/bin/env bash
# Usage: git jira-plan
# Interactively plan a Jira ticket before creating a branch.
# Writes context to .git/jira-staged-ticket.json for the post-checkout hook.

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)
if [ -z "$GIT_DIR" ]; then
  echo "[jira] ERROR: Not in a git repository."
  exit 1
fi

STAGED_FILE="${GIT_DIR}/jira-staged-ticket.json"

# Check if a ticket is already staged
if [ -f "$STAGED_FILE" ]; then
  EXISTING=$(jq -r '.summary' "$STAGED_FILE" 2>/dev/null)
  echo "[jira] A ticket is already staged: $EXISTING"
  printf "Overwrite? (y/N): "
  read -r CONFIRM
  if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "[jira] Cancelled."
    exit 0
  fi
fi

# Prompt for title
echo ""
printf "Title (after \"QA Automation (TALA v3) | \"): "
read -r TITLE_INPUT

if [ -z "$TITLE_INPUT" ]; then
  echo "[jira] ERROR: Title cannot be empty."
  exit 1
fi

SUMMARY="QA Automation (TALA v3) | ${TITLE_INPUT}"

# Prompt for description
echo ""
printf "Description: "
read -r DESCRIPTION

if [ -z "$DESCRIPTION" ]; then
  DESCRIPTION="No description provided."
fi

# Enhance description using Claude
if [ "$DESCRIPTION" != "No description provided." ]; then
  echo ""
  ENHANCE_TIMEOUT=30
  echo "[jira] Enhancing description (${ENHANCE_TIMEOUT}s timeout)..."
  ENHANCE_PROMPT="You are a QA engineer writing Jira ticket descriptions. Rewrite the following into a professional, clear, and concise description suitable for a Jira story. Keep it to 2-3 sentences max. Only output the enhanced description text, nothing else.

Input: ${DESCRIPTION}"

  # Portable timeout wrapper — prefer coreutils, fall back to bash background/kill.
  # Stderr from claude is intentionally NOT redirected so failure reasons surface.
  if command -v gtimeout >/dev/null 2>&1; then
    ENHANCED=$(gtimeout "$ENHANCE_TIMEOUT" claude -p --output-format text "$ENHANCE_PROMPT")
    ENHANCE_RC=$?
  elif command -v timeout >/dev/null 2>&1; then
    ENHANCED=$(timeout "$ENHANCE_TIMEOUT" claude -p --output-format text "$ENHANCE_PROMPT")
    ENHANCE_RC=$?
  else
    ENHANCE_TMP=$(mktemp -t jira-plan-enhance.XXXXXX)
    claude -p --output-format text "$ENHANCE_PROMPT" >"$ENHANCE_TMP" &
    ENHANCE_PID=$!
    ( sleep "$ENHANCE_TIMEOUT" && kill -TERM "$ENHANCE_PID" 2>/dev/null ) &
    ENHANCE_WATCHER=$!
    wait "$ENHANCE_PID" 2>/dev/null
    ENHANCE_RC=$?
    kill "$ENHANCE_WATCHER" 2>/dev/null
    wait "$ENHANCE_WATCHER" 2>/dev/null || true
    ENHANCED=$(cat "$ENHANCE_TMP")
    rm -f "$ENHANCE_TMP"
  fi

  if [ "$ENHANCE_RC" -eq 0 ] && [ -n "$ENHANCED" ]; then
    DESCRIPTION="$ENHANCED"
    echo "[jira] Enhanced description: $DESCRIPTION"
  else
    if [ "$ENHANCE_RC" -eq 124 ] || [ "$ENHANCE_RC" -eq 143 ]; then
      REASON="timed out after ${ENHANCE_TIMEOUT}s"
    elif [ "$ENHANCE_RC" -ne 0 ]; then
      REASON="claude exited with code ${ENHANCE_RC}"
    else
      REASON="claude returned empty output"
    fi
    echo ""
    echo "[jira] !!! WARNING: Description enhancement FAILED — ${REASON}."
    echo "[jira] !!! Using the original description unchanged. Re-run 'git jira-plan' to retry,"
    echo "[jira] !!! or edit the description in Jira after the ticket is created."
    echo ""
  fi
fi

# Write staging file
jq -n \
  --arg summary "$SUMMARY" \
  --arg description "$DESCRIPTION" \
  '{ summary: $summary, description: $description }' > "$STAGED_FILE"

echo ""
echo "[jira] Staged ticket:"
echo "  Summary:     $SUMMARY"
echo "  Description: $DESCRIPTION"
echo ""
echo "[jira] Now create your branch:"
echo "  git checkout -b feature/your-branch-name"
echo ""
