#!/usr/bin/env bash
# Shared Jira transition helper — sourced by post-checkout and pre-push hooks.
# Requires JIRA_BASE_URL, JIRA_USER_EMAIL, JIRA_API_TOKEN to be set by the caller.

# ── jira_curl ────────────────────────────────────────────────
# Wraps curl so the Jira credentials never enter argv (visible via `ps`).
# The `user = ...` config is fed on stdin via `--config -`, so only the
# non-secret flags (URL, headers, payload) appear in the process list.
jira_curl() {
  curl "$@" --config - <<CURLCFG
user = "${JIRA_USER_EMAIL}:${JIRA_API_TOKEN}"
CURLCFG
}

jira_transition() {
  local TICKET_KEY="$1"
  local TARGET_PATTERN="$2"

  if [ -z "$TICKET_KEY" ] || [ -z "$TARGET_PATTERN" ]; then
    echo "[jira] ERROR: jira_transition requires <TICKET_KEY> <TARGET_PATTERN>"
    return 1
  fi

  if [ -z "$JIRA_BASE_URL" ] || [ -z "$JIRA_USER_EMAIL" ] || [ -z "$JIRA_API_TOKEN" ]; then
    echo "[jira] WARNING: Missing Jira credentials for transition."
    return 1
  fi

  # Step 1: GET available transitions
  local RESPONSE
  RESPONSE=$(jira_curl -sS -w "\n%{http_code}" \
    -X GET \
    -H "Content-Type: application/json" \
    "${JIRA_BASE_URL}/rest/api/3/issue/${TICKET_KEY}/transitions" 2>/dev/null)

  local HTTP_CODE
  HTTP_CODE=$(echo "$RESPONSE" | tail -1)
  local BODY
  BODY=$(echo "$RESPONSE" | sed '$d')

  if [ "$HTTP_CODE" != "200" ]; then
    echo "[jira] WARNING: Failed to get transitions for $TICKET_KEY (HTTP $HTTP_CODE)"
    return 1
  fi

  # Step 2: Find matching transition by TARGET STATUS name (case-insensitive)
  # Matches on .to.name (destination status) rather than .name (transition label)
  # because transition names can be arbitrary while status names are standardized.
  local TRANSITION_ID
  TRANSITION_ID=$(echo "$BODY" | jq -r \
    --arg pattern "$TARGET_PATTERN" \
    '[.transitions[] | select(.to.name | test($pattern; "i"))] | first | .id // empty')

  if [ -z "$TRANSITION_ID" ]; then
    local AVAILABLE
    AVAILABLE=$(echo "$BODY" | jq -r '.transitions[] | "\(.name) → \(.to.name)"' 2>/dev/null | tr '\n' ', ')
    echo "[jira] WARNING: No transition to status matching '$TARGET_PATTERN' for $TICKET_KEY"
    echo "[jira]   Available: ${AVAILABLE:-none}"
    return 1
  fi

  # Step 3: POST the transition
  local TRANS_RESPONSE
  TRANS_RESPONSE=$(jira_curl -sS -o /dev/null -w "%{http_code}" \
    -X POST \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg id "$TRANSITION_ID" '{transition:{id:$id}}')" \
    "${JIRA_BASE_URL}/rest/api/3/issue/${TICKET_KEY}/transitions" 2>/dev/null)

  if [ "$TRANS_RESPONSE" = "204" ]; then
    return 0
  else
    echo "[jira] WARNING: Transition POST failed for $TICKET_KEY (HTTP $TRANS_RESPONSE)"
    return 1
  fi
}
