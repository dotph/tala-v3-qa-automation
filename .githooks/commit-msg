#!/usr/bin/env bash
# Warn (never block) if the commit SUBJECT line is missing a leading Jira
# ticket key. Per CONTRIBUTING.md every commit subject should be
# `<TICKET-ID> <type>(<scope>): <subject>` — e.g. `QATEAM-1007 chore(hooks): …`.
# Body lines are left untouched and merge/revert/fixup/squash/amend commits
# are skipped (git or higher-level tooling wrote those).

COMMIT_MSG_FILE="$1"
[ -f "$COMMIT_MSG_FILE" ] || exit 0

FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")

# Skip generated commits — git or higher-level tooling wrote these.
case "$FIRST_LINE" in
  "Merge "*|"Revert "*|fixup!*|squash!*|amend!*) exit 0 ;;
esac

# Accept "QATEAM-1234 <rest>" or "QATEAM-1234: <rest>" — lenient on the
# separator, strict on the shape (Jira project key + digits at the very
# start; the project starts with a letter and may carry digits after it,
# e.g. TALA3-71). The key must be followed by whitespace OR end-of-line,
# so a subject that's ONLY the ticket key (no trailing type/scope) still
# passes — the hook's job is to warn on missing key, not on terse copy.
# Only the presence of the key is checked; the type/scope grammar lives
# in CONTRIBUTING.md and code review.
if ! [[ "$FIRST_LINE" =~ ^[A-Z][A-Z0-9]*-[0-9]+:?([[:space:]]|$) ]]; then
  echo "[jira] WARNING: commit subject does not start with a Jira ticket key."
  echo "[jira]          Expected: '<TICKET-ID> <type>(<scope>): <subject>' (see CONTRIBUTING.md)."
fi

exit 0
