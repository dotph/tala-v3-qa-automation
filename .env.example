# Runtime properties for the TALA v3 QA automation suite.
#
# These are NOT auto-loaded — the project consumes them as Maven system properties
# (`-D...` on the command line). This file documents the contract so contributors
# (and CI maintainers) know what's supported and what the defaults are.
#
# Usage:
#   mvn test -DtestEnv=PRODUCTION -DexchangeRate=58.20 -Dheadless=true
#
# Source of truth:
#   - testEnv / exchangeRate → src/main/java/config/EnvConfig.java
#   - headless              → src/main/java/utils/PlaywrightUtils.java

# Test environment: MDOT (default, https://mdot.ph) | PRODUCTION (https://dot.ph)
TEST_ENV=MDOT

# USD → PHP exchange rate used in the footer forex assertion.
EXCHANGE_RATE=60.50

# Run Chromium in headless mode. CI overrides to true.
HEADLESS=false
